

let os = "linux";

switch(os)
{
    case "windows" : {
        print("WINDOWS OS");
        break;
    }

    case "linux": {
        print("LINUX OS");
        break;
    }

    case "macos": {
        print("Mac Os");
        break;
    }

    default: {
        print("No such Os");
        break;
    }
}